{
  "name": "personal",
  "description": "Personal development preset with full spec-kit workflow, session logging, and GitHub integration",
  "version": "1.0.0",
  "extends": "default",
  "constitution": {
    "principles": ["modularity", "minimalism", "security", "test-coverage", "spec-kit-workflow"],
    "workflow": "specify → clarify → plan → tasks → implement → analyze"
  },
  "hooks": {
    "enabled": ["session-logger"]
  },
  "extensions": {
    "recommended": [
      "https://github.com/aaronrsun/spec-kit-checkpoint",
      "https://github.com/dsrednicki/spec-kit-cleanup",
      "https://github.com/KhawarHabibKhan/spec-kit-status",
      "https://github.com/KhawarHabibKhan/spec-kit-doctor"
    ]
  }
}
